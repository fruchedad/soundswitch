{
  "manifest_version": 3,
  "name": "SoundSwitch - SoundCloud View Toggle",
  "version": "1.0.0",
  "description": "Toggle between public and authenticated views on SoundCloud profiles with power-user features",
  "author": "SoundSwitch",
  
  "permissions": [
    "cookies",
    "activeTab",
    "storage",
    "scripting",
    "alarms"
  ],
  
  "host_permissions": [
    "https://*.soundcloud.com/*",
    "https://api.soundcloud.com/*",
    "https://api-v2.soundcloud.com/*"
  ],
  
  "background": {
    "service_worker": "background.js"
  },
  
  "content_scripts": [
    {
      "matches": ["https://*.soundcloud.com/*"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  
  "web_accessible_resources": [
    {
      "resources": ["icons/*"],
      "matches": ["https://*.soundcloud.com/*"]
    }
  ]
} 